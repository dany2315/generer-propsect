{
  "name": "generer-propspect-sci",
  "version": "1.0.0",
  "description": "MVP pour identifier des SCI propriétaires / bailleurs potentiels, enrichir les données publiques disponibles, scorer les sociétés qui ressemblent le plus à des clients potentiels de BailNotarie, puis préparer une prospection multicanal.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "collect": "tsx scripts/collect-sci.ts",
    "collect:test": "tsx scripts/collect-sci.ts --departements 75,92 --max-pages 3 --once",
    "collect:once": "tsx scripts/collect-sci.ts --once --max-pages 40 --sleep 300",
    "collect:pause": "powershell -ExecutionPolicy Bypass -File scripts/pause-collection.ps1",
    "collect:resume": "powershell -ExecutionPolicy Bypass -File scripts/resume-collection.ps1",
    "workers:status": "powershell -ExecutionPolicy Bypass -File scripts/workers-status.ps1",
    "enrich": "tsx scripts/enrich-sci.ts",
    "enrich:once": "tsx scripts/enrich-sci.ts --once --batch 100",
    "enrich:web": "tsx scripts/enrich-web-contacts.ts",
    "enrich:web:once": "tsx scripts/enrich-web-contacts.ts --once --batch 10",
    "discover:contacts": "tsx scripts/discover-contact-leads.ts",
    "discover:contacts:once": "tsx scripts/discover-contact-leads.ts --once --batch 5",
    "extract:establishments": "tsx scripts/extract-establishments.ts",
    "extract:establishments:once": "tsx scripts/extract-establishments.ts --once --batch 250",
    "enrich:rne": "tsx scripts/enrich-rne-inpi.ts",
    "enrich:rne:once": "tsx scripts/enrich-rne-inpi.ts --once --batch 20",
    "enrich:sirene": "tsx scripts/enrich-sirene-complete.ts",
    "enrich:sirene:once": "tsx scripts/enrich-sirene-complete.ts --once --batch 50",
    "inpi:ftp:list": "tsx scripts/inpi-ftp-list.ts",
    "inpi:ftp:inventory": "tsx scripts/inpi-ftp-inventory.ts",
    "inpi:ftp:download": "tsx scripts/inpi-ftp-download.ts",
    "inpi:rne:index": "tsx scripts/index-rne-formalites.ts",
    "inpi:rne:index:once": "tsx scripts/index-rne-formalites.ts --once --batch 10",
    "inpi:rne:extract": "tsx scripts/extract-rne-profiles.ts",
    "inpi:rne:extract:once": "tsx scripts/extract-rne-profiles.ts --once --batch 500"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "prisma": "^6.19.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
